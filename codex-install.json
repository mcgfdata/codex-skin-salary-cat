{
  "schemaVersion": 1,
  "packageType": "codex-dream-skin-theme",
  "version": "0.3.3",
  "repository": "https://github.com/mcgfdata/codex-skin-salary-cat",
  "author": {
    "name": "终端极客",
    "github": "mcgfdata"
  },
  "theme": {
    "id": "preset-yuexinmiao-payday",
    "name": "月薪喵 · 今日营业",
    "presetDirectory": "presets/preset-yuexinmiao-payday"
  },
  "themes": [
    {
      "id": "preset-yuexinmiao-payday",
      "name": "月薪喵 · 今日营业",
      "presetDirectory": "presets/preset-yuexinmiao-payday",
      "default": true
    },
    {
      "id": "preset-yuexinmiao",
      "name": "月薪喵",
      "presetDirectory": "presets/preset-yuexinmiao",
      "default": false
    }
  ],
  "selection": {
    "defaultThemeId": "preset-yuexinmiao-payday",
    "surface": "Codex Dream Skin 已保存的主题"
  },
  "runtime": {
    "required": true,
    "repository": "https://github.com/Fei-Away/Codex-Dream-Skin",
    "schemaVersion": 1,
    "validatedVersion": "1.2.0"
  },
  "bootstrap": {
    "triggerPrompt": "帮我设置 Codex 皮肤 mcgfdata/codex-skin-salary-cat，作者是终端极客",
    "skillName": "codex-skin-salary-cat",
    "systemSkill": "skill-installer",
    "repositoryPath": "skills/codex-skin-salary-cat",
    "continueInCurrentTask": true,
    "archiveFallback": "https://github.com/mcgfdata/codex-skin-salary-cat/archive/refs/heads/main.zip"
  },
  "dependencies": {
    "automaticallyInstalled": {
      "macos": ["Codex Dream Skin runtime"],
      "windows": ["Node.js 22", "Codex Dream Skin runtime"]
    },
    "systemProvided": {
      "macos": ["curl", "ditto"],
      "windows": ["Windows PowerShell 5.1 or newer", "Expand-Archive"]
    },
    "userProvided": ["Official Codex Desktop", "HTTPS network access"],
    "rebuildOnly": ["Python 3.9 or newer", "Pillow 11.3.0"],
    "gitRequired": false,
    "administratorRequired": false
  },
  "platforms": {
    "macos": {
      "detectRuntime": "~/.codex/codex-dream-skin-studio/scripts/switch-theme-macos.sh",
      "detectRuntimeMarker": "~/Library/Application Support/CodexDreamSkinStudio/theme-backup.json",
      "installCommand": "./scripts/install-theme-macos.sh",
      "installOnlyCommand": "./scripts/install-theme-macos.sh --no-apply",
      "fullSetupCommand": "./Setup.command",
      "safeSetupCommand": "./scripts/setup-skin-macos.sh --no-apply",
      "automaticResumeAfterQuit": true,
      "restartPolicy": "one-confirmation-auto-restart",
      "themeDirectory": "~/Library/Application Support/CodexDreamSkinStudio/themes/preset-yuexinmiao-payday",
      "themeDirectories": [
        "~/Library/Application Support/CodexDreamSkinStudio/themes/preset-yuexinmiao-payday",
        "~/Library/Application Support/CodexDreamSkinStudio/themes/preset-yuexinmiao"
      ]
    },
    "windows": {
      "detectRuntime": "%LOCALAPPDATA%\\CodexDreamSkin\\engine\\scripts\\theme-windows.ps1",
      "detectRuntimeMarker": "%LOCALAPPDATA%\\CodexDreamSkin\\config.before-dream-skin.toml.appearance.json",
      "installCommand": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\Install.ps1",
      "installOnlyCommand": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\Install.ps1 -NoApply",
      "fullSetupCommand": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\Setup.ps1",
      "themeDirectory": "%LOCALAPPDATA%\\CodexDreamSkin\\themes\\preset-yuexinmiao-payday",
      "themeDirectories": [
        "%LOCALAPPDATA%\\CodexDreamSkin\\themes\\preset-yuexinmiao-payday",
        "%LOCALAPPDATA%\\CodexDreamSkin\\themes\\preset-yuexinmiao"
      ]
    }
  },
  "artwork": {
    "sourceCount": 1,
    "source": "source/salary-cat-source.png",
    "license": "CC-BY-4.0",
    "attribution": "月薪喵主题作者：终端极客"
  }
}
